# ------------------------------------------------------------------------------
# Configuration template for the ONDEWO SIP nodejs client SDK examples.
#
# This is a NON-SECRET template: fill in real values locally, but never commit
# real credentials. Every example loads this file via dotenv (path relative to
# the script), so the values below are read from process.env at run time.
# ------------------------------------------------------------------------------

# --- Connection: the SIP gRPC endpoint (host + port are combined into host:port) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=50053

# --- Secure channel: TLS toggle and optional root certificate path ---
# Set ONDEWO_USE_SECURE_CHANNEL=true to open a TLS channel. Leave ONDEWO_GRPC_CERT
# empty to use the system default root certificates.
ONDEWO_USE_SECURE_CHANNEL=false
ONDEWO_GRPC_CERT=

# --- Keycloak: D18 offline-token (ROPC) login used to authenticate the SIP client ---
# The SDK uses a PUBLIC client, so KEYCLOAK_CLIENT_SECRET is normally left blank.
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-sip-cai-sdk-public
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
KEYCLOAK_VERIFY_SSL=true
